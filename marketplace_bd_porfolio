CREATE VIEW public.v_fulfillment_metrics AS
 SELECT sh.warehouse_id,
    w.name AS warehouse,
    w.city,
    count(*) AS shipments_total,
    count(*) FILTER (WHERE (sh.delivered_at IS NOT NULL)) AS delivered,
    round(avg((EXTRACT(epoch FROM (sh.shipped_at - o.created_at)) / (3600)::numeric)) FILTER (WHERE (sh.shipped_at IS NOT NULL)), 1) AS avg_processing_hours,
    round(avg(((EXTRACT(epoch FROM (sh.delivered_at - sh.shipped_at)) / (3600)::numeric) / (24)::numeric)) FILTER (WHERE (sh.delivered_at IS NOT NULL)), 1) AS avg_delivery_days,
    round(avg(((EXTRACT(epoch FROM (sh.delivered_at - o.created_at)) / (3600)::numeric) / (24)::numeric)) FILTER (WHERE (sh.delivered_at IS NOT NULL)), 1) AS avg_total_days
   FROM ((public.shipments sh
     JOIN public.orders o ON ((o.id = sh.order_id)))
     JOIN public.warehouses w ON ((w.id = sh.warehouse_id)))
  GROUP BY sh.warehouse_id, w.name, w.city;


